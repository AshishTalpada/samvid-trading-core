# Python Core
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# Data and Persistence
data/
logs/
questdb_data/
questdb/
outputs/
scratch/
*.db
*.sqlite
*.sqlite3
*.log

# Root-level Clutter (Keep src/ clean)
# Ignore all .py scripts in root as they are temporary utilities
/*.py
!/setup.py

# Ignore all temporary docs/notes in root (except README)
/*.md
/*.txt
/*.bak
/*.bin
/*.json
/*.temp
/*.tmp
!/README.md
!/package.json
!/package-lock.json

# Version artifacts / Junk files
=
[0-9]*.[0-9]*

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env
frontend/.env.local

# Credentials
.env
.env.local
vault.json
credentials.json
*.key
*.pem
*.p12

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
