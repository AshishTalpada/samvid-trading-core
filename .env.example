# 🪐 Samvid Core - Comprehensive Environment Template

# --- CORE SYSTEM CONFIGURATION ---
TRADING_MODE=PAPER          # PAPER or LIVE
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
DMS_ENABLED=false           # Enable Hardware Dead Man Switch
SESSION_SECRET=SECURE_RANDOM_STRING_HERE
PROJECT_PATH=./

# --- DEAD MAN'S SWITCH (DMS) ---
DMS_HOST=0.0.0.0             # Secondary machine listens here
DMS_PORT=9999
DMS_HEARTBEAT_INTERVAL=60    # Seconds between heartbeats
DMS_TIMEOUT_SECONDS=300      # Emergency timeout (seconds)

# --- INFRASTRUCTURE: QUESTDB ---
QUESTDB_HOST=localhost
QUESTDB_PORT=9009           # ILP Port
QUESTDB_PG_PORT=8812        # Postgres Port
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_CONNECT_TIMEOUT_SEC=10

# --- BROKER: INTERACTIVE BROKERS (IBKR) ---
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_INTERFACE=gateway      # gateway or tws
IBKR_PATH=C:\path\to\ibkr

# --- BROKER: METATRADER 5 (MT5) ---
MT5_LOGIN=YOUR_MT5_LOGIN
MT5_PASSWORD=YOUR_MT5_PASSWORD
MT5_SERVER=YOUR_MT5_SERVER
MT5_PATH=C:\path\to\terminal64.exe

# --- FTMO CHALLENGE CONFIGURATION ---
FTMO_ACCOUNT_SIZE=10000      # e.g. 10000, 25000, 50000
FTMO_ALLOCATION_USD=5000     # Specific allocation for FTMO strategies

# --- ALERTS: TELEGRAM ---
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID
TELEGRAM_PIN=0000
TELEGRAM_API_URL=https://api.telegram.org

# --- INTELLIGENCE: SWARM & LLM ---
USE_LOCAL_LLM=true          # true for Ollama, false for OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OLLAMA_URLS=http://localhost:11434/v1
OLLAMA_MODEL_FAST=qwen2.5:1.5b
OLLAMA_MODEL_HEAVY=phi3:mini

# --- MARKET DATA PROVIDERS ---
OPENBB_PAT=YOUR_OPENBB_PAT
FMP_API_KEY=YOUR_FMP_KEY
TIINGO_API_KEY=YOUR_TIINGO_KEY
POLYGON_API_KEY=YOUR_POLYGON_KEY
ALPHA_VANTAGE_API_KEY=YOUR_AV_KEY

# --- RISK & PERFORMANCE ---
STARTING_CAPITAL_USD=1000.0
MAX_RISK_PER_TRADE_PCT=1.0   # e.g. 0.5, 1.0
F16_DECISION_MODE=B          # A=allow override | B=never override
COMMISSION_PER_ROUND_TRIP=1.5

# --- TELEMETRY ---
API_SERVER_PORT=8000
DASHBOARD_URL=http://localhost:3000
