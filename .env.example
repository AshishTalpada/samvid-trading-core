# 🪐 Samvid Core - Environment Configuration Template

# --- ACCOUNT CONFIGURATION ---
# Replace with your actual starting capital and risk parameters
STARTING_CAPITAL_USD=1000
ALLOCATION_PRIMARY=500
ALLOCATION_SECONDARY=500

# --- BROKER INTERFACES ---
# IBKR (Interactive Brokers) TWS/Gateway Configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# MetaTrader 5 (MT5) Configuration
MT5_LOGIN=YOUR_LOGIN_ID
MT5_SERVER=YOUR_SERVER_NAME

# --- SYSTEM SECURITY ---
# Access to these is handled securely via vault.py
# Use vault_setup.py to initialize these in your local OS Vault
API_KEY_PRIMARY=SECURE_VAULT_REQUIRED
API_KEY_SECONDARY=SECURE_VAULT_REQUIRED

# --- TELEMETRY & DASHBOARD ---
API_SERVER_PORT=8000
DASHBOARD_URL=http://localhost:3000

# --- OPERATIONAL MODES ---
# PAPER (Simulation) or LIVE (Real Capital)
EXECUTION_MODE=PAPER
LOG_LEVEL=INFO
# DEAD_MAN_SWITCH: Enable for hardware-integrated safety (DMS)
DMS_ENABLED=false
