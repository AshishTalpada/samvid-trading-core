# ═══════════════════════════════════════════════════════════════════
# UNIFIED TRADING SYSTEM V3.0 — ENVIRONMENT TEMPLATE
# Copy to .env and fill in your real values
# NEVER commit .env to Git — it is in .gitignore
# ═══════════════════════════════════════════════════════════════════
# NOTE: IBKR is REGULAR MARGIN (not RRSP) — keep CRA tax records
# NOTE: DMS is your iPhone via Telegram — no secondary script needed
# NOTE: FTMO $25K Swing Account — open free trial first at ftmo.com
# ═══════════════════════════════════════════════════════════════════

# ── AI APIS ─────────────────────────────────────────────────────────
# Claude (https://console.anthropic.com) — Agent B mapping tier
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Local Tier-2 fallback — install Ollama (https://ollama.com) then: ollama pull llama3
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3

# ── MARKET DATA ──────────────────────────────────────────────────────
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY_HERE

# ── IBKR CANADA ──────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT_ID=YOUR_IBKR_ACCOUNT_ID
# -- Automated Login (Requires IBC: https://github.com/IbcAlpha/IBC) --
IBKR_PAPER_USERNAME=YOUR_IBKR_USERNAME
IBKR_PAPER_PASSWORD=YOUR_IBKR_PASSWORD
IBC_PATH="C:\\IBC"
TWS_PATH="C:\\Jts"

# ── MT5 / FTMO ───────────────────────────────────────────────────────
MT5_LOGIN=YOUR_MT5_LOGIN
MT5_PASSWORD=YOUR_MT5_PASSWORD
MT5_SERVER=YOUR_MT5_SERVER
MT5_PATH="C:\\Program Files\\MetaTrader 5\\terminal64.exe"

# ── TELEGRAM ALERTS ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID


# ── TRADING MODE ─────────────────────────────────────────────────────
TRADING_MODE=paper                           # paper | live (NEVER change to live prematurely)

# ── CAPITAL (from your completed questionnaire) ───────────────────────
STARTING_CAPITAL_CAD=500
IBKR_ALLOCATION_CAD=255
FTMO_ALLOCATION_CAD=245

# ── FTMO CHALLENGE SIZE ───────────────────────────────────────────────
FTMO_ACCOUNT_SIZE=10000                      # 10000 | 25000 | 50000 | 100000

# ── RISK SETTINGS (from questionnaire 5.06) ──────────────────────────
RISK_PER_TRADE=1.0                           # 0.5 | 1.0 | 1.5 (percent)
F16_DECISION=B                               # A=allow override | B=never override

# ── DEAD MAN'S SWITCH ─────────────────────────────────────────────────
DMS_HOST=0.0.0.0                             # Secondary machine listens here
DMS_PORT=9999
DMS_HEARTBEAT_INTERVAL=60                    # Seconds between heartbeats
DMS_TIMEOUT_SECONDS=300                      # 5 min timeout before emergency close

# ── SYSTEM PATHS ─────────────────────────────────────────────────────
PROJECT_PATH=./                              # Root directory of this project
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR

# ── QUESTDB (time-series + brain fast OHLCV reads) ───────────────────
# Start locally: PowerShell: .\scripts\start_questdb.ps1   OR   docker compose -f docker-compose.questdb.yml up -d
# Console: http://127.0.0.1:9000   ILP: 9009   PostgreSQL wire: 8812
QUESTDB_ENABLED=true
QUESTDB_HOST=127.0.0.1
QUESTDB_PORT=9009
QUESTDB_PG_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest
QUESTDB_CONNECT_TIMEOUT_SEC=5

# ── EMBEDDED API (FastAPI) ───────────────────────────────────────────
# If 8000 is busy, change port here (e.g. 8010) and open http://127.0.0.1:8010/health
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8000

# ── OPENBB (free account at https://my.openbb.co) ───────────────────
OPENBB_PAT=

# ── MIROFISH SWARM INTELLIGENCE ─────────────────────────────────────
# Run locally: cd MiroFish && npm run dev   (or Docker: docker compose up -d)
MIROFISH_API_URL=http://localhost:5001
