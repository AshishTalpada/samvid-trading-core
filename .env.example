# ═══════════════════════════════════════════════════════════════════
# Sovereign Trading System — Environment Variables Template
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════

# ── Runtime mode ────────────────────────────────────────────────────
# paper | ibkr_paper | live
TRADING_MODE=paper
# Set to 1 to force paper mode regardless of TRADING_MODE
FORCED_PAPER_MODE=1

# ── Capital ─────────────────────────────────────────────────────────
STARTING_CAPITAL_CAD=100000

# ── Security ────────────────────────────────────────────────────────
# REQUIRED — used for session signing and HMAC exec tokens
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# ── IBKR ────────────────────────────────────────────────────────────
# Leave blank if running paper-only
IBKR_ACCOUNT_ID=
IBKR_HOST=host.docker.internal   # TWS/Gateway running on the host machine
IBKR_PORT=7497                   # 7497 = paper, 7496 = live

# ── MT5 ─────────────────────────────────────────────────────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# ── Telegram alerts ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── QuestDB ─────────────────────────────────────────────────────────
QUESTDB_ENABLED=true
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest

# ── AI providers ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Ports ───────────────────────────────────────────────────────────
API_PORT=8000
METRICS_PORT=9090

# ── Grafana ─────────────────────────────────────────────────────────
GRAFANA_PASSWORD=sovereign
