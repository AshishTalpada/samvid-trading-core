{
    "python.envFile": "${workspaceFolder}/.env",
    "files.exclude": {
        "**/logs/**": true,
        "**/data/**": true,
        "**/frontend/dist/**": true,
        "**/.venv_clean/**": true,
        "**/*.pyc": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/.mypy_cache/**": true
    },
    "search.exclude": {
        "**/logs/**": true,
        "**/data/**": true,
        "**/frontend/dist/**": true,
        "**/.venv_clean/**": true
    }
}
