{
    "python.analysis.extraPaths": [
        ".",
        "src"
    ],
    "python.analysis.typeCheckingMode": "off",
    "python.analysis.exclude": [
        "venv",
        ".venv",
        "data",
        "logs",
        "outputs",
        "**/node_modules",
        "**/__pycache__",
        "**/.*"
    ],
    "python.analysis.reportMissingImports": "none",
    "python.analysis.reportMissingModuleSource": "none",
    "python.analysis.autoImportCompletions": true,
    "python.autoComplete.extraPaths": [
        ".",
        "src"
    ],
    "python.envFile": "${workspaceFolder}/.env",
    "files.exclude": {
        "**/logs/**": true,
        "**/data/**": true,
        "**/frontend/dist/**": true,
        "**/*.pyc": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/.mypy_cache/**": true
    },
    "search.exclude": {
        "**/logs/**": true,
        "**/data/**": true,
        "**/frontend/dist/**": true
    }
}
