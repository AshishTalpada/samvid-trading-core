{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": [
    "src/**",
    "tests/**",
    "scripts/**",
    "tools/**",
    "docs/**",
    "specs/**",
    "contracts/**",
    "frontend/src/**"
  ],
  "exclude": [
    "frontend/dist/**",
    "dist/**",
    "node_modules/**",
    "venv/**",
    ".venv/**",
    "**/__pycache__/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**"
  ]
}